{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Auto-sync @ozzylabs/skills (ozzy-labs/skills) via Renovate customManagers + git-refs. Extend per-adapter sub-presets (skills-sync/<adapter-id>) to opt in to adapter outputs. See https://github.com/ozzy-labs/skills#consumer-setup",
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["**/.commons/sync.yaml", "**/.dev-config/sync.yaml"],
      "matchStrings": ["skills_commit:\\s*(?<currentDigest>[a-f0-9]{7,40})"],
      "currentValueTemplate": "main",
      "depNameTemplate": "ozzy-labs/skills",
      "packageNameTemplate": "https://github.com/ozzy-labs/skills",
      "datasourceTemplate": "git-refs"
    }
  ],
  "packageRules": [
    {
      "matchDepNames": ["ozzy-labs/skills"],
      "matchDatasources": ["git-refs"],
      "commitMessageTopic": "skills",
      "commitMessageExtra": "to {{newDigestShort}}",
      "labels": ["chore", "skills-sync"],
      "semanticCommits": "enabled",
      "semanticCommitType": "chore",
      "semanticCommitScope": "deps"
    }
  ]
}
